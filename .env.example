# AutoML Studio — Environment Variables
# Copy this file to .env and fill in the values.

# Flask secret key (REQUIRED — generate a random string)
SECRET_KEY=change-me-to-a-random-string

# Google Gemini API key (required for LLM features)
GEMINI_API_KEY=

# OpenAI API key (optional alternative LLM)
OPENAI_API_KEY=

# Firebase credentials (optional — for cloud sync)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Backblaze B2 storage (optional — for cloud model storage)
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=

# CORS allowed origins (comma-separated, defaults to http://localhost:7860)
ALLOWED_ORIGINS=http://localhost:7860

# Maximum upload file size in MB (default: 100)
MAX_UPLOAD_MB=100

# Session TTL in seconds (default: 7200 = 2 hours)
SESSION_TTL=7200
